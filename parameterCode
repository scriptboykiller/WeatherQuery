可以。你先写一个最小版 JavaParser 方法，只解决一件事：

> 根据 filePath + methodName + @Param 名称，拿到真实 Java 参数类型。



先不搞反射，不搞重载，不搞跨类。

public Optional<String> resolveParameterType(
        final Path javaFile,
        final String methodName,
        final String sqlParameterName) {

    try {
        final CompilationUnit compilationUnit = StaticJavaParser.parse(javaFile);

        return compilationUnit.findAll(MethodDeclaration.class).stream()
                .filter(method -> method.getNameAsString().equals(methodName))
                .flatMap(method -> method.getParameters().stream())
                .filter(parameter -> matchesParamName(parameter, sqlParameterName))
                .map(parameter -> parameter.getType().asString())
                .findFirst();

    } catch (IOException exception) {
        return Optional.empty();
    }
}

private boolean matchesParamName(
        final Parameter parameter,
        final String sqlParameterName) {

    final Optional<AnnotationExpr> paramAnnotation =
            parameter.getAnnotationByName("Param");

    if (paramAnnotation.isPresent()
            && paramAnnotation.get().isSingleMemberAnnotationExpr()) {

        final String annotationValue = paramAnnotation.get()
                .asSingleMemberAnnotationExpr()
                .getMemberValue()
                .toString()
                .replace("\"", "");

        return annotationValue.equals(sqlParameterName);
    }

    return parameter.getNameAsString().equals(sqlParameterName);
}

